rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read access to all content collections
    match /services/{serviceId} { allow read: if true; allow write: if true; }
    match /offers/{offerId} { allow read: if true; allow write: if true; }
    match /gallery/{itemId} { allow read: if true; allow write: if true; }
    match /testimonials/{testimonialId} { allow read: if true; allow write: if true; }
    match /maintenance/{recordId} { allow read: if true; allow write: if true; }
    match /stats/{docId} { allow read: if true; allow write: if true; }
    
    // Global fallback for reading
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
